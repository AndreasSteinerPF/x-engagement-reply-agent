# Copy this file to .env (gitignored) and fill in real values for local
# testing. See src/config/env.ts for the authoritative schema -- every
# variable here is optional at load time, but handler.ts/invoke-local.ts
# require the ones needed for whichever --live-* flags you pass.
# Loaded automatically by `npm run invoke:local` / `npm run asana:discover`
# via `node --env-file-if-exists=.env` -- no dependency needed, Node 20.6+.

AWS_REGION=us-east-2

# X API v2 (candidate-supplied, paid tier required for third-party timelines)
X_BEARER_TOKEN=

# Asana (get GIDs by running: npm run asana:discover)
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
ASANA_SECTION_GID=
ASANA_ASSIGNEE_GID=
ASANA_ARTICLE_THRESHOLD_ASSIGNEE_GID=
ASANA_SIMILARITY_SCORE_CUSTOM_FIELD_GID=
ASANA_TASK_SIMILARITY_SCORE_CUSTOM_FIELD_GID=
ASANA_SUBTASK_SIMILARITY_SCORE_CUSTOM_FIELD_GID=
ASANA_EXISTING_TASK_DEDUPE_ENABLED=

# LangSmith (optional -- LLM tracing)
LANGSMITH_TRACING=
LANGSMITH_PROJECT=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=

# DynamoDB state table (only needed for the real Lambda handler, Phase 6 --
# invoke-local.ts uses --persist for a local file-backed alternative instead)
STATE_TABLE_NAME=
