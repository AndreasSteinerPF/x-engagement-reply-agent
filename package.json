{
  "name": "x-engagement-reply-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Scheduled X (Twitter) engagement poller that matches posts against Soofi Safavi's article corpus via the hosted investors-mcp MCP, drafts recommended replies with an LLM, and creates Asana approval tasks for human review.",
  "scripts": {
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "cdk synth --strict",
    "deploy": "cdk deploy --require-approval never",
    "invoke:local": "node --env-file-if-exists=.env --import tsx scripts/invoke-local.ts",
    "asana:discover": "node --env-file-if-exists=.env --import tsx scripts/asana-discover.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.2",
    "aws-cdk": "^2.1129.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.15.0",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.17.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.12",
    "@aws-sdk/client-dynamodb": "^3.1079.0",
    "@aws-sdk/client-secrets-manager": "^3.1079.0",
    "@aws-sdk/credential-providers": "^3.1079.0",
    "@aws-sdk/lib-dynamodb": "^3.1079.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^7.0.16",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.4.2",
    "langsmith": "^0.7.15",
    "p-limit": "^7.3.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
